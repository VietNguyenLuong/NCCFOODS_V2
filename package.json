    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "memorystore": "^1.6.7",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "pug": "^3.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
