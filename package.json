{
  "name": "fruitshop",
  "version": "3.0.0",
  "description": "FruitShop — Node.js + Pug + MongoDB (production-ready)",
  "main": "app.js",
  "scripts": {
    "start": "NODE_ENV=production node app.js",
    "cluster": "NODE_ENV=production pm2 start ecosystem.config.js",
