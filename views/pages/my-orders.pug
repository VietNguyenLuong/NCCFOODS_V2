extends ../layout
block content
  .page-hero
    .container
      h1.page-title Don hang cua toi
  section.section
    .container
      if !orders.length
        .cart-empty(style="text-align:center;padding:60px 0")
          p(style="font-size:48px;margin-bottom:12px") 📦
          p(style="color:var(--slate);margin-bottom:20px") Ban chua co don hang nao
          a.btn.btn-primary(href="/products") Mua hang ngay
      else
        each o in orders
          .my-order-card
            div
              p(style="font-family:var(--font-mono);font-size:.8rem;color:var(--slate);margin-bottom:4px") ##{o.orderCode}
              p(style="font-weight:700;font-size:1rem;color:var(--ink);margin-bottom:6px")= o.items.map(i => i.emoji + i.name).join(', ')
              p(style="font-size:.82rem;color:var(--slate)")= new Date(o.createdAt).toLocaleDateString('vi-VN')
            div(style="text-align:right")
              span.status-b(class='sb-'+o.status style="display:inline-block;padding:5px 14px;border-radius:99px;font-size:.72rem;font-weight:700")= o.status
              p(style="font-family:var(--font-display);font-size:1.3rem;font-weight:900;color:var(--jade);margin-top:8px")= (o.total/1000).toFixed(0) + '.000d'
