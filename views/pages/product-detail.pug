extends ../layout
include ../partials/product-card

block content
  section.section.detail-section(style="padding-top:120px")
    .container(style="max-width:1000px")

      p.breadcrumb
        a(href="/") Trang chủ
        span.bc-sep  /
        a(href="/products") Sản phẩm
        span.bc-sep  /
        span.bc-cur= product.name

      .detail-main
        //- ANH SAN PHAM
        .detail-left
          .product-image-wrap
            if product.image
              img.product-main-img(src=product.image alt=product.name)
            else
              .product-emoji-wrap
                span(style="font-size:130px;filter:drop-shadow(0 12px 28px rgba(0,0,0,.1))") #{product.emoji || '🍎'}
          if product.image
            p.img-badge ✓ Ảnh thực tế sản phẩm

        //- THONG TIN + VARIANTS
        .detail-right
          if product.category
            a.section-label(href="/products?cat=#{product.category.slug}" style="text-decoration:none")
              = product.category.emoji + ' ' + product.category.name

          if product.badge
            span.p-badge(class=product.badge style="display:inline-block;margin:8px 0 12px")
              = product.badge === 'new' ? 'MỚI' : product.badge === 'hot' ? 'HOT 🔥' : 'SALE'

          h1.detail-title= product.name

          if product.origin
            p.detail-origin 📍 Xuất xứ: #{product.origin}

          if product.description
            p.detail-desc= product.description

          -
            const hasVariants = product.variants && product.variants.length > 0
            const firstVariant = hasVariants ? product.variants[0] : null
            const initPrice = hasVariants ? firstVariant.price : product.price

          .price-wrap
            span.detail-price#detailPrice= (initPrice/1000).toFixed(0) + '.000đ'
            span.detail-unit / #{product.unit || 'kg'}
            if hasVariants
              span.variant-price-hint  (giá theo loại đã chọn)

          if hasVariants
            .variant-selector
              p.variant-label Chọn loại / size:
              .variant-chips
                each v, i in product.variants
                  button.variant-chip(
                    type="button"
                    data-price=v.price
                    data-label=v.label
                    data-vid=String(v._id)
                    class=(i === 0 ? 'active' : '')
                    onclick="selectVariant(this)"
                  )
                    span.vc-label= v.label
                    span.vc-price= (v.price/1000).toFixed(0) + '.000đ'

          .qty-row
            label(style="font-size:.85rem;font-weight:700;color:var(--ink)") Số lượng:
            .qty-control
              button.qty-btn(onclick="adj(-1)") −
              input#qtyInput(type="number" min="1" value="1")
              button.qty-btn(onclick="adj(1)") +

          .detail-actions
            button.btn.btn-primary#addDetailBtn(
              data-id=String(product._id)
              data-name=product.name
              data-price=initPrice
              data-emoji=product.emoji
            ) 🛒 Thêm vào giỏ
            a.btn.btn-outline(href="/cart") Xem giỏ hàng →

          .trust-row
            each badge in [['✓','Hoa quả tươi'],['🚚','Giao 24h'],['💯','Hoàn tiền 100%']]
              .trust-item
                span= badge[0]
                |  #{badge[1]}

      if related && related.length
        .related-section
          h2.related-title Sản phẩm tương tự
          .products-grid
            each p in related
              +productCard(p, 0)

block scripts
  script.
    var selectedVariant = !{JSON.stringify(firstVariant ? { price: firstVariant.price, label: firstVariant.label, id: String(firstVariant._id) } : null)};

    window.selectVariant = function(btn) {
      document.querySelectorAll('.variant-chip').forEach(function(c) { c.classList.remove('active') })
      btn.classList.add('active')
      var price = parseInt(btn.dataset.price)
      selectedVariant = { price: price, label: btn.dataset.label, id: btn.dataset.vid }
      document.getElementById('detailPrice').textContent = (price/1000).toFixed(0) + '.000W'
      document.getElementById('addDetailBtn').dataset.price = price
    }

    function adj(d) {
      var inp = document.getElementById('qtyInput')
      inp.value = Math.max(1, parseInt(inp.value || 1) + d)
    }

    document.getElementById('addDetailBtn').addEventListener('click', function() {
      var qty   = parseInt(document.getElementById('qtyInput').value) || 1
      var id    = this.dataset.id
      var name  = this.dataset.name
      var emoji = this.dataset.emoji
      var price = parseInt(this.dataset.price)

      var cartName = selectedVariant ? name + ' (' + selectedVariant.label + ')' : name
      var cartId   = selectedVariant ? id + '_' + selectedVariant.id : id

      var cart = JSON.parse(localStorage.getItem('fs-cart') || '[]')
      var ex   = cart.find(function(c) { return c.id === cartId })
      if (ex) {
        ex.qty += qty
      } else {
        cart.push({ id: cartId, productId: id, name: cartName, price: price, emoji: emoji, qty: qty, variant: selectedVariant ? selectedVariant.label : '' })
      }
      localStorage.setItem('fs-cart', JSON.stringify(cart))
      updateCartCount()
      showToast(emoji + ' ' + cartName + ' x' + qty + ' đã vào giỏ!')
    })
