extends ../layout
block content
  .auth-page
    .auth-card
      p.auth-logo 🍊 NCCFOODS
      p.auth-sub Đăng nhập để mua hàng
      if flash
        p.auth-success= flash
      if error
        p.auth-error= error
      form.auth-form(method="POST" action="/auth/login")
        div
          label Email
          input(type="email" name="email" placeholder="email@example.com" required autofocus)
        div
          label Mật khẩu
          input(type="password" name="password" placeholder="••••••••" required)
        button.btn.btn-primary.btn-block(type="submit") Đăng nhập →
      p.auth-switch Chưa có tài khoản? #[a(href="/auth/register") Đăng ký ngay]
