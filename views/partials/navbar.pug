nav.navbar#navbar
  a.nav-logo(href="/")
    span.nav-logo-icon 🍊
    span FruitShop
  ul.nav-links
    li: a(href="/") Trang chu
    li: a(href="/products") San pham
    li: a(href="/cart") Gio hang
    if currentUser
      li: a(href="/my-orders") Don hang cua toi
  .nav-actions
    if currentUser
      .nav-user
        .nav-user-avatar= currentUser.name[0].toUpperCase()
        span= currentUser.name
      a.btn.btn-ghost.btn-sm(href="/auth/logout") Dang xuat
    else
      a.btn.btn-ghost.btn-sm(href="/auth/login") Dang nhap
      a.btn.btn-primary.btn-sm(href="/auth/register") Dang ky
    a.btn.btn-outline.btn-sm(href="/cart") 🛒 Gio hang #[span#navCartCount(style="background:var(--jade);color:#fff;border-radius:50%;width:18px;height:18px;font-size:11px;font-weight:700;display:inline-flex;align-items:center;justify-content:center;margin-left:4px") 0]
