doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(property="og:image" content="https://scontent.fhan3-1.fna.fbcdn.net/v/t39.30808-6/616249577_855035657537319_4466169680203698136_n.jpg?stp=dst-jpg_s590x590_tt6&_nc_cat=111&ccb=1-7&_nc_sid=7b2446&_nc_eui2=AeGBBMTJFPwbIohl6uH1Ruix6XvKLw2tS5npe8ovDa1Lmevc7J6H9niYp8RUX-mGR2cVZFcDXD2BJF6T3QJJ2YxD&_nc_ohc=NF6zqqbKE3sQ7kNvwGJlrct&_nc_oc=AdpWLuQC8BfKGi3avnNwBtpOL2Z_u1AP-Ir-iWINe_bWei1ZWKNqpp_8G3gfrWLw-LuldqV9E5lPLzpVGvRE8Sy6&_nc_zt=23&_nc_ht=scontent.fhan3-1.fna&_nc_gid=Rx0KCHXDvokqNMLhBK6QbQ&_nc_ss=7a3a8&oh=00_Af1rHmbQXBRM1UKkbUXB7JGlJQJME2ZrHQfac2QtK1iNNA&oe=69DE99A6")
    meta(property="og:url" content="https://nccfoods.com")
    meta(property="og:type" content="website")
    title= title
    link(rel="stylesheet" href="/css/style.css")
    block head

  body
    .cursor#cursor
    .cursor-trail#cursorTrail

    .loader#loader
      .loader-fruits
        span.loader-fruit 🍊
        span.loader-fruit 🍇
        span.loader-fruit 🍓
        span.loader-fruit 🥭
      .loader-bar

    include partials/navbar

    main
      block content

    include partials/footer

    button.chat-fab#chatFab(aria-label="Chat tu van") 🤖

    .chat-win#chatWin
      .chat-head
        .chat-head-info
          .chat-head-ava 🌿
          div
            p.chat-head-name NCCFOODS AI
            p.chat-head-status Online · Tư vấn dinh dương
        button.chat-close-btn#chatCloseBtn ✕
      .chat-msgs#chatMsgs
        .chat-msg.bot Xin chao! 🍊 Toi la NCCFOODS — trợ lý dinh dưỡng của NCCFOODS. Bạn muốn tư vấn về sản phẩm nào, chế độ ăn uống hay sức khỏe?
        .chat-typing#chatTyping
          .typing-dot
          .typing-dot
          .typing-dot
      .chat-input-wrap
        textarea.chat-textarea#chatInput(placeholder="Hoi ve dinh duong, hoa qua..." rows="1")
        button.chat-send-btn#chatSend ➤

    .toast#toast
      span#toastMsg Thêm vào giỏ hàng!

    script(src="/js/main.js")
    block scripts
