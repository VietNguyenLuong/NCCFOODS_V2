extends layout
block content
  - const currentPage = 'shipped'
  .p-acts
    p.p-acts-title Đơn hàng đã gửi
    span.s-badge.s-shipped= orders.length + ' don'
  .tbl-wrap
    if orders.length
      table.a-table
        thead
          tr
            th Mã đơn
            th Khách hàng
            th SDT
            th Tổng tiền
            th Ngày gửi
            th Thao tác
        tbody
          each o in orders
            tr
              td: code= o.orderCode
              td= o.customerName
              td= o.phone
              td= (o.total/1000).toFixed(0) + '.000d'
              td= o.shippedAt ? new Date(o.shippedAt).toLocaleDateString('vi-VN') : '-'
              td(style="display:flex;gap:6px")
                a.a-btn.a-btn-view(href=`/admin/orders/${o._id}`) Chi tiết
                button.a-btn.a-btn-restore(onclick=`doRestore('${o._id}')`) Khôi phục
    else
      .empty-state
        span.es-icon 🚚
        p Chưa có đơn nào được gửi

block scripts
  script.
    async function doRestore(id){
      if(!confirm('Khoi phuc don hang nay?'))return
      const r=await api('/admin/orders/'+id+'/restore',{})
      if(r.success){atoast('Da khoi phuc!','ok');setTimeout(()=>location.reload(),700)}
    }
