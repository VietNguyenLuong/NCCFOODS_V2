extends layout
block content
  - const currentPage = 'pending'
  .p-acts
    p.p-acts-title Đơn hàng chờ xác nhận
    span.s-badge.s-pending= orders.length + ' don'
  form.date-filter(method="GET" action="/admin/orders/pending")
    input(type="date" name="from" value=from)
    input(type="date" name="to" value=to)
    button(type="submit") Lọc
    if from || to
      a.a-btn.a-btn-cancel(href="/admin/orders/pending") Xóa lọc
  .tbl-wrap
    if orders.length
      table.a-table
        thead
          tr
            th Mã đơn
            th Khách hàng
            th SDT
            th Tổng tiền
            th Bill
            th Ngày đặt
            th Thao tác
        tbody
          each o in orders
            tr
              td: code= o.orderCode
              td= o.customerName
              td= o.phone
              td= (o.total/1000).toFixed(0) + '.000d'
              td
                if o.billImage
                  a.a-btn.a-btn-view(href=o.billImage target="_blank") Xem bill
                else
                  span(style="color:var(--coral);font-size:.74rem") Chưa có
              td= new Date(o.createdAt).toLocaleDateString('vi-VN')
              td(style="display:flex;gap:6px;flex-wrap:wrap")
                a.a-btn.a-btn-view(href=`/admin/orders/${o._id}`) Chi tiết
                button.a-btn.a-btn-confirm(onclick=`doAction('${o._id}','confirm')`) Xác nhận
    else
      .empty-state
        span.es-icon 🎉
        p Không có đơn nào chờ xử lý

block scripts
  script.
    async function doAction(id,action){
      if(!confirm('Xac nhan don hang nay?'))return
      const r=await api('/admin/orders/'+id+'/'+action,{})
      if(r.success){atoast('Thanh cong!','ok');setTimeout(()=>location.reload(),700)}
      else atoast('Loi!','err')
    }
