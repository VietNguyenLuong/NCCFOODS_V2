doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Admin Login — FruitShop
    link(rel="stylesheet" href="/css/admin.css")
  body.a-login-wrap
    .a-login-card
      p.a-login-logo 🍊 Admin
      p.a-login-sub Trang quan tri FruitShop
      if error
        p.a-login-error ⚠️ #{error}
      form.a-login-form(method="POST" action="/admin/login")
        div
          label Email quan tri
          input(type="email" name="email" placeholder="admin@fruitshop.vn" required autofocus)
        div
          label Mat khau
          input(type="password" name="password" placeholder="••••••••" required)
        button.a-login-btn(type="submit") Dang nhap →
